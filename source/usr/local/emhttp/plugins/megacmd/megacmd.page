<script>
function megacmdViewLogs() {
  $.get('/plugins/megacmd/include/viewlogs.php', function(data) {
    var esc = $('<div>').text(data).html();
    swal({
      title: '_(Recent logs)_',
      text: '<pre style="text-align:left;max-height:75vh;overflow:auto;background:#222;color:#0f0;padding:8px;white-space:pre-wrap;word-break:break-all;font-size:0.85em;">' + esc + '</pre>',
      html: true,
      width: '90%',
      confirmButtonText: '_(Close)_'
    });
    $('.sweet-alert').css({'width': '90%', 'max-width': '1400px'});
  });
}

$(function() {
  $('.megacmd-ajax-form').on('submit', function(e) {
    e.preventDefault();
    var $f = $(this);
    $f.find('button[type=submit]').prop('disabled', true);
    $.post('/plugins/megacmd/include/action.php', $f.serialize()).always(function() {
      location.reload();
    });
  });
  <? if ($loggedIn): ?>
  $('#mc_localpath').fileTreeAttach();
  <? endif; ?>
});
</script>

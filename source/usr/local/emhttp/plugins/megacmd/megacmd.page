Menu="Utilities"
Title="MEGAcmd"
Icon="icon.png"
---
<?
require_once "/usr/local/emhttp/plugins/megacmd/include/common.php";

if (session_status() !== PHP_SESSION_ACTIVE) session_start();
$message = $_SESSION['megacmd_message'] ?? "";
unset($_SESSION['megacmd_message']);

$installedMegacmdVersion = getPlgEntity('megacmd_version');
$latestMegacmdVersion = $_SESSION['megacmd_latest_checked'] ?? null;

$running = serviceRunning();
$whoami = $running ? megaExec("mega-whoami")["output"] : "";
$loggedIn = $running && stripos($whoami, "not logged in") === false && trim($whoami) !== "";
$syncList = $running && $loggedIn ? megaExec("mega-sync")["output"] : "";
$syncHistory = $running && $loggedIn
  ? megaExec("mega-transfers --show-completed --show-syncs --limit=50 --path-display-size=40")["output"]
  : "";
$syncs = $running && $loggedIn ? megaListSyncs() : [];
$remoteDirs = $loggedIn ? megaListRemoteDirs("/") : [];

$accountEmail = "";
if ($loggedIn && preg_match('/Account e-mail:\s*(.+)/i', trim($whoami), $m)) {
  $accountEmail = trim($m[1]);
}
?>
<link type="text/css" rel="stylesheet" href="/webGui/styles/jquery.filetree.css">
<script src="/webGui/javascript/jquery.filetree.js" charset="utf-8"></script>
<style>
.megacmd-box {
  margin-bottom: 20px;
  padding: 14px 18px 18px;
  background: rgba(128,128,128,0.06);
  border: 1px solid rgba(128,128,128,0.25);
  border-radius: 6px;
  max-width: 100%;
  box-sizing: border-box;
}
.megacmd-box h3 {
  margin: -14px -18px 14px;
  padding: 10px 18px;
  border-bottom: 1px solid rgba(128,128,128,0.25);
  font-size: 1.05em;
}
.megacmd-box h4 { margin: 18px 0 8px; }
.megacmd-field { margin-bottom: 16px; }
.megacmd-field label { display: block; margin-bottom: 4px; }
.megacmd-field select, .megacmd-field input[type=text], .megacmd-field input[type=password] {
  display: block;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.megacmd-field select { margin-bottom: 6px; }
.megacmd-field.megacmd-narrow input { max-width: 140px; }
.megacmd-stack-btn { display: block; margin-top: 8px; }
.megacmd-msg { background:#222; color:#0f0; padding:8px; width:100%; white-space:pre; font-family:monospace; max-height:200px; box-sizing:border-box; overflow:auto; }
.megacmd-status-ok { color: #4a4; font-weight: bold; }
.megacmd-status-bad { color: #a44; font-weight: bold; }
.megacmd-email {
  font-family: monospace;
  font-size: 1.1em;
  background: rgba(128,128,128,0.15);
  border: 1px solid rgba(128,128,128,0.25);
  padding: 3px 8px;
  border-radius: 4px;
}
.megacmd-hint { display: block; color: #888; font-size: 0.85em; margin-top: 4px; }
.megacmd-intro { margin: 0 0 20px; color: #aaa; }
</style>

<p class="megacmd-intro">Sync files between your MEGA cloud storage account and any Unraid share, powered by MEGAcmd (MEGA's official command-line client). Log in below, then add syncs between a local path and a MEGA folder.</p>

<div class="megacmd-box">
  <h3>Service</h3>
  <p>Status:
    <?= $running ? '<span class="megacmd-status-ok">Running</span>' : '<span class="megacmd-status-bad">Stopped</span>' ?>
  </p>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="start"><button type="submit">Start</button>
  </form>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="stop"><button type="submit">Stop</button>
  </form>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="restart"><button type="submit">Restart</button>
  </form>
</div>

<div class="megacmd-box">
  <h3>MEGAcmd version</h3>
  <p>Installed: <code class="megacmd-email"><?= htmlspecialchars($installedMegacmdVersion) ?></code></p>
  <? if ($latestMegacmdVersion !== null): ?>
    <? if (version_compare($latestMegacmdVersion, $installedMegacmdVersion, '>')): ?>
      <p>Update available: <code class="megacmd-email"><?= htmlspecialchars($latestMegacmdVersion) ?></code></p>
      <form class="megacmd-ajax-form" method="post" style="display:inline">
        <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
        <input type="hidden" name="action" value="updatemegacmd">
        <button type="submit">Update to <?= htmlspecialchars($latestMegacmdVersion) ?></button>
      </form>
    <? else: ?>
      <p>Already up to date.</p>
    <? endif; ?>
  <? endif; ?>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="checkmegacmdupdate">
    <button type="submit">Check for updates</button>
  </form>
</div>

<? if ($running): ?>
<div class="megacmd-box">
  <h3>Account</h3>
  <? if ($loggedIn): ?>
    <? if ($accountEmail !== ""): ?>
      <p>Account e-mail: <code class="megacmd-email"><?= htmlspecialchars($accountEmail) ?></code></p>
    <? else: ?>
      <p><?= htmlspecialchars($whoami) ?></p>
    <? endif; ?>
    <form class="megacmd-ajax-form" method="post">
      <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
      <input type="hidden" name="action" value="logout">
      <button type="submit">Logout</button>
    </form>
  <? else: ?>
    <form class="megacmd-ajax-form" method="post">
      <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
      <input type="hidden" name="action" value="login">
      <div class="megacmd-field"><label>Email</label><input type="text" name="email"></div>
      <div class="megacmd-field"><label>Password</label><input type="password" name="password"></div>
      <div class="megacmd-field megacmd-narrow"><label>2FA code (if enabled)</label><input type="text" name="authcode"></div>
      <button type="submit">Login</button>
    </form>
  <? endif; ?>
</div>

<? if ($loggedIn): ?>
<div class="megacmd-box">
  <h3>Current syncs</h3>
  <div class="megacmd-msg"><?= htmlspecialchars($syncList) ?></div>
</div>

<div class="megacmd-box">
  <h3>Sync history</h3>
  <? if (trim($syncHistory) !== ""): ?>
    <div class="megacmd-msg"><?= htmlspecialchars($syncHistory) ?></div>
  <? else: ?>
    <p>No completed sync transfers yet.</p>
  <? endif; ?>
</div>

<div class="megacmd-box">
  <h3>Add sync</h3>
  <form class="megacmd-ajax-form" method="post">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="addsync">
    <div class="megacmd-field">
      <label>Local path</label>
      <input type="text" id="mc_localpath" name="localpath" autocomplete="off" spellcheck="false"
             data-pickfolders="true" data-pickfilter="HIDE_FILES_FILTER"
             data-pickroot="<?=is_dir('/mnt/user') ? '/mnt/user' : '/mnt'?>"
             placeholder="Click to select a folder">
    </div>
    <div class="megacmd-field">
      <label>Remote path</label>
      <select id="mc_remoteselect" onchange="if(this.value) document.getElementById('mc_remotepath').value=this.value;">
        <option value="">-- existing folder --</option>
        <? foreach ($remoteDirs as $dir): ?>
          <option value="/<?= htmlspecialchars($dir) ?>">/<?= htmlspecialchars($dir) ?></option>
        <? endforeach; ?>
      </select>
      <input type="text" id="mc_remotepath" name="remotepath" placeholder="/example">
      <small class="megacmd-hint">Pick an existing remote folder, or type a path (a new folder name will be created).</small>
    </div>
    <button type="submit">Add sync</button>
  </form>
</div>

<div class="megacmd-box">
  <h3>Remove sync</h3>
  <form class="megacmd-ajax-form" method="post">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="removesync">
    <? if ($syncs): ?>
      <div class="megacmd-field">
        <select name="syncid">
          <? foreach ($syncs as $s): ?>
            <option value="<?= htmlspecialchars($s['id']) ?>"><?= htmlspecialchars($s['local']) ?> &rarr; <?= htmlspecialchars($s['remote']) ?> (<?= htmlspecialchars($s['id']) ?>)</option>
          <? endforeach; ?>
        </select>
      </div>
      <button type="submit" class="megacmd-stack-btn">Remove</button>
    <? else: ?>
      <p>No syncs configured.</p>
    <? endif; ?>
  </form>
</div>
<? endif; ?>
<? endif; ?>

<? if ($message !== ""): ?>
<div class="megacmd-box">
  <h3>Last command output</h3>
  <div class="megacmd-msg"><?= htmlspecialchars($message) ?></div>
</div>
<? endif; ?>

<script>
$(function() {
  $('.megacmd-ajax-form').on('submit', function(e) {
    e.preventDefault();
    var $f = $(this);
    $f.find('button[type=submit]').prop('disabled', true);
    $.post('/plugins/megacmd/include/action.php', $f.serialize()).always(function() {
      location.reload();
    });
  });
  <? if ($loggedIn): ?>
  $('#mc_localpath').fileTreeAttach();
  <? endif; ?>
});
</script>

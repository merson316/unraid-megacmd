Menu="Utilities"
Title="MEGAcmd"
Icon="fa-cloud-upload-alt"
---
<?
require_once "/usr/local/emhttp/plugins/megacmd/include/common.php";

if (session_status() !== PHP_SESSION_ACTIVE) session_start();
$message = $_SESSION['megacmd_message'] ?? "";
unset($_SESSION['megacmd_message']);

$running = serviceRunning();
$whoami = $running ? megaExec("mega-whoami")["output"] : "";
$loggedIn = $running && stripos($whoami, "not logged in") === false && trim($whoami) !== "";
$syncList = $running && $loggedIn ? megaExec("mega-sync")["output"] : "";
$syncs = $running && $loggedIn ? megaListSyncs() : [];
$remoteDirs = $loggedIn ? megaListRemoteDirs("/") : [];

$accountEmail = "";
if ($loggedIn && preg_match('/Account e-mail:\s*(.+)/i', trim($whoami), $m)) {
  $accountEmail = trim($m[1]);
}
?>
<link type="text/css" rel="stylesheet" href="/webGui/styles/jquery.filetree.css">
<script src="/webGui/javascript/jquery.filetree.js" charset="utf-8"></script>
<style>
.megacmd-box {
  margin-bottom: 20px;
  padding: 14px 18px 18px;
  background: rgba(128,128,128,0.06);
  border: 1px solid rgba(128,128,128,0.25);
  border-radius: 6px;
  max-width: 100%;
  box-sizing: border-box;
}
.megacmd-box h3 {
  margin: -14px -18px 14px;
  padding: 10px 18px;
  border-bottom: 1px solid rgba(128,128,128,0.25);
  font-size: 1.05em;
}
.megacmd-box h4 { margin: 18px 0 8px; }
.megacmd-box table { margin-bottom: 10px; }
.megacmd-box td { padding: 3px 8px 3px 0; vertical-align: middle; }
.megacmd-box select, .megacmd-box input[type=text], .megacmd-box input[type=password] {
  display: block;
  width: 100%;
  max-width: 400px;
  box-sizing: border-box;
}
.megacmd-box select { margin-bottom: 6px; }
.megacmd-box .megacmd-stack-btn { display: block; margin-top: 8px; }
.megacmd-msg { background:#222; color:#0f0; padding:8px; white-space:pre; font-family:monospace; max-height:200px; max-width:100%; overflow:auto; }
.megacmd-status-ok { color: #4a4; font-weight: bold; }
.megacmd-status-bad { color: #a44; font-weight: bold; }
.megacmd-email {
  font-family: monospace;
  font-size: 1.1em;
  background: rgba(128,128,128,0.15);
  border: 1px solid rgba(128,128,128,0.25);
  padding: 3px 8px;
  border-radius: 4px;
}
.megacmd-hint { display: block; color: #888; font-size: 0.85em; margin-top: 4px; }
</style>

<div class="megacmd-box">
  <h3>Service</h3>
  <p>Status:
    <?= $running ? '<span class="megacmd-status-ok">Running</span>' : '<span class="megacmd-status-bad">Stopped</span>' ?>
  </p>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="start"><button type="submit">Start</button>
  </form>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="stop"><button type="submit">Stop</button>
  </form>
  <form class="megacmd-ajax-form" method="post" style="display:inline">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="restart"><button type="submit">Restart</button>
  </form>
</div>

<? if ($running): ?>
<div class="megacmd-box">
  <h3>Account</h3>
  <? if ($loggedIn): ?>
    <? if ($accountEmail !== ""): ?>
      <p>Account e-mail: <code class="megacmd-email"><?= htmlspecialchars($accountEmail) ?></code></p>
    <? else: ?>
      <p><?= htmlspecialchars($whoami) ?></p>
    <? endif; ?>
    <form class="megacmd-ajax-form" method="post">
      <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
      <input type="hidden" name="action" value="logout">
      <button type="submit">Logout</button>
    </form>
  <? else: ?>
    <form class="megacmd-ajax-form" method="post">
      <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
      <input type="hidden" name="action" value="login">
      <table>
        <tr><td>Email</td><td><input type="text" name="email" size="40"></td></tr>
        <tr><td>Password</td><td><input type="password" name="password" size="40"></td></tr>
        <tr><td>2FA code (if enabled)</td><td><input type="text" name="authcode" size="10"></td></tr>
      </table>
      <button type="submit">Login</button>
    </form>
  <? endif; ?>
</div>

<? if ($loggedIn): ?>
<div class="megacmd-box">
  <h3>Current syncs</h3>
  <div class="megacmd-msg"><?= htmlspecialchars($syncList) ?></div>
</div>

<div class="megacmd-box">
  <h3>Add sync</h3>
  <form class="megacmd-ajax-form" method="post">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="addsync">
    <table>
      <tr>
        <td>Local path</td>
        <td>
          <input type="text" id="mc_localpath" name="localpath" size="50" autocomplete="off" spellcheck="false"
                 data-pickfolders="true" data-pickfilter="HIDE_FILES_FILTER"
                 data-pickroot="<?=is_dir('/mnt/user') ? '/mnt/user' : '/mnt'?>"
                 placeholder="Click to select a folder">
        </td>
      </tr>
      <tr>
        <td>Remote path</td>
        <td>
          <select id="mc_remoteselect" onchange="if(this.value) document.getElementById('mc_remotepath').value=this.value;">
            <option value="">-- existing folder --</option>
            <? foreach ($remoteDirs as $dir): ?>
              <option value="/<?= htmlspecialchars($dir) ?>">/<?= htmlspecialchars($dir) ?></option>
            <? endforeach; ?>
          </select>
          <input type="text" id="mc_remotepath" name="remotepath" size="30" placeholder="/example">
          <small class="megacmd-hint">Pick an existing remote folder, or type a path (a new folder name will be created).</small>
        </td>
      </tr>
    </table>
    <button type="submit">Add sync</button>
  </form>
</div>

<div class="megacmd-box">
  <h3>Remove sync</h3>
  <form class="megacmd-ajax-form" method="post">
    <input type="hidden" name="csrf_token" value="<?=$var['csrf_token']?>">
    <input type="hidden" name="action" value="removesync">
    <? if ($syncs): ?>
      <select name="syncid">
        <? foreach ($syncs as $s): ?>
          <option value="<?= htmlspecialchars($s['id']) ?>"><?= htmlspecialchars(shortenPath($s['local'])) ?> &rarr; <?= htmlspecialchars(shortenPath($s['remote'])) ?> (<?= htmlspecialchars($s['id']) ?>)</option>
        <? endforeach; ?>
      </select>
      <button type="submit" class="megacmd-stack-btn">Remove</button>
    <? else: ?>
      <p>No syncs configured.</p>
    <? endif; ?>
  </form>
</div>
<? endif; ?>
<? endif; ?>

<? if ($message !== ""): ?>
<div class="megacmd-box">
  <h3>Last command output</h3>
  <div class="megacmd-msg"><?= htmlspecialchars($message) ?></div>
</div>
<? endif; ?>

<script>
$(function() {
  $('.megacmd-ajax-form').on('submit', function(e) {
    e.preventDefault();
    var $f = $(this);
    $f.find('button[type=submit]').prop('disabled', true);
    $.post('/plugins/megacmd/include/action.php', $f.serialize()).always(function() {
      location.reload();
    });
  });
  <? if ($loggedIn): ?>
  $('#mc_localpath').fileTreeAttach();
  <? endif; ?>
});
</script>

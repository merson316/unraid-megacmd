<?
require_once "/usr/local/emhttp/plugins/megacmd/include/common.php";

if (session_status() !== PHP_SESSION_ACTIVE) session_start();
$message = $_SESSION['megacmd_message'] ?? "";
unset($_SESSION['megacmd_message']);

$installedMegacmdVersion = getPlgEntity('megacmd_version');
$latestMegacmdVersion = $_SESSION['megacmd_latest_checked'] ?? null;
$cfg = getConfig();
$storageReady = appdataStorageReady();

$running = $storageReady && serviceRunning();
$whoami = $running ? megaExec("mega-whoami")["output"] : "";
$loggedIn = $running && stripos($whoami, "not logged in") === false && trim($whoami) !== "";
$syncList = $running && $loggedIn ? megaExec("mega-sync --path-display-size=200")["output"] : "";
$syncHistory = $running && $loggedIn
  ? fixTransferTypeAlignment(megaExec("mega-transfers --show-completed --show-syncs --limit=50 --path-display-size=200")["output"])
  : "";
$syncs = $running && $loggedIn ? megaListSyncs() : [];
$remoteDirs = $loggedIn ? megaListRemoteDirs("/") : [];
$backupList = $running && $loggedIn ? megaExec("mega-backup -l --path-display-size=200")["output"] : "";
$backups = $running && $loggedIn ? megaListBackups() : [];
$backupHistory = $running && $loggedIn ? megaExec("mega-backup -h --path-display-size=200")["output"] : "";
$backupHistoryMarker = "-- HISTORY OF BACKUPS --";
$pos = strpos($backupHistory, $backupHistoryMarker);
if ($pos !== false) $backupHistory = substr($backupHistory, $pos);

$accountEmail = "";
if ($loggedIn && preg_match('/Account e-mail:\s*(.+)/i', trim($whoami), $m)) {
  $accountEmail = trim($m[1]);
}
?>
